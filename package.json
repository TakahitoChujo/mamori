{
  "name": "mamori",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "preset": "react-native",
    "transform": {
      "^.+\\.(ts|tsx|js|jsx)$": [
        "babel-jest",
        {
          "presets": [
            "babel-preset-expo"
          ]
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*|zustand|@react-native-async-storage)"
    ],
    "setupFiles": [
      "./jest.setup.ts"
    ],
    "moduleNameMapper": {
      "^expo$": "<rootDir>/__mocks__/expo.js",
      "^expo/(.*)$": "<rootDir>/__mocks__/emptyModule.js",
      "\\.(mp3|wav|ogg)$": "<rootDir>/__mocks__/emptyModule.js"
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "expo": "~55.0.5",
    "expo-audio": "~55.0.8",
    "expo-crypto": "^55.0.9",
    "expo-haptics": "^55.0.8",
    "expo-location": "^55.1.2",
    "expo-notifications": "^55.0.11",
    "expo-secure-store": "^55.0.8",
    "expo-sms": "^55.0.8",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-maps": "1.26.20",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-uuid": "^2.0.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^55.0.10",
    "jest": "~29.7.0",
    "jest-expo": "^55.0.9",
    "typescript": "~5.9.2"
  },
  "private": true
}
